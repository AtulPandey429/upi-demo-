{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm run install:all",
  "rewrites": [
    { "source": "/(.*)", "destination": "/server.js" }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 30,
      "includeFiles": "frontend/dist/**"
    }
  }
}
